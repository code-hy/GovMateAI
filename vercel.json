{
  "builds": [
    {
      "src": "api/asgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/asgi.py"
    }
  ],
  "env": {
    "FASTEMBED_CACHE_PATH": "/tmp/fastembed"
  }
}
