# DeepSeek API (get key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat

# Qdrant — local (Docker) or cloud (free at https://cloud.qdrant.io)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key
# QDRANT_HTTPS=true

# PostgreSQL — local (Docker) or cloud (free at https://neon.tech)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/govmate_db
